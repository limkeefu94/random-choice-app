GCP_PROJECT_ID=your-google-cloud-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_ALLOWED_ORIGIN=https://your-app.vercel.app

# Firestore 使用同一组 Google service account 凭证。
# 需要在 Google Cloud 开启 Firestore Native mode，并给 service account Firestore/Datastore 写入权限。

# 推荐：把完整 service account JSON 转成 base64 后放到 Vercel Environment Variables
GCS_SERVICE_ACCOUNT_JSON_BASE64=base64-encoded-service-account-json

# 备用方案：不用 base64 JSON 时才填这两个
# GCP_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
# GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 兼容旧命名，不需要和 GCP_* 同时填写
# GCS_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
