APP_ENV=development
GCP_PROJECT_ID=your-google-cloud-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
APP_ALLOWED_ORIGIN=https://your-app.vercel.app

# Development only: set true to reflect any request Origin in API CORS responses.
ALLOW_DEV_CORS=false

# Future social features are scaffolded but hidden during development.
SOCIAL_FEATURES_ENABLED=false

# 账号登录令牌密钥：建议在 Vercel 里放一串随机长文本。
# AUTH_TOKEN_SECRET is required in production; development may fallback to the Google service account private key.
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret

# Firestore 使用同一组 Google service account 凭证。
# 需要在 Google Cloud 开启 Firestore Native mode，并给 service account Firestore/Datastore 写入权限。

# 推荐：把完整 service account JSON 转成 base64 后放到 Vercel Environment Variables
GCS_SERVICE_ACCOUNT_JSON_BASE64=base64-encoded-service-account-json

# 备用方案：不用 base64 JSON 时才填这两个
# GCP_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
# GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 兼容旧命名，不需要和 GCP_* 同时填写
# GCS_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Anonymous Firestore sync is disabled by default for production safety.
# Set to true only in local/dev environments that intentionally allow anonymous browser sync.
ALLOW_ANON_SYNC=false

# GCS uploads require login by default. Set to true only for local/dev public upload testing.
ALLOW_PUBLIC_UPLOAD=false

# Per-user/per-IP upload rate limit for /api/gcs-upload and /api/gcs-signed-url.
UPLOAD_RATE_LIMIT_MAX=12
UPLOAD_RATE_LIMIT_WINDOW_MS=900000

# Auth rate limits. Set ALLOW_DEV_RATE_LIMITS=true in local/dev to use wider defaults.
ALLOW_DEV_RATE_LIMITS=false
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_REGISTER_RATE_LIMIT_MAX=3
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=3600000
